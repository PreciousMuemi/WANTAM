# .env Template
# Copy this file to .env and fill in your actual values

# Supabase Configuration (Required for database storage and vector search)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Choose Embedding Provider (uncomment one)
EMBEDDING_PROVIDER=gemini
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_PROVIDER=openai
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_PROVIDER=cohere

# Choose LLM Provider (uncomment one)
LLM_PROVIDER=gemini
# LLM_PROVIDER=ollama
# LLM_PROVIDER=claude

# API Keys (only needed for cloud providers)
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=sk-...
CLAUDE_API_KEY=sk-ant-...
COHERE_API_KEY=your-cohere-key
HF_API_KEY=your-huggingface-token

# Ollama Configuration (if using local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat

# Tesseract OCR Path (Optional - only needed if not in system PATH)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# macOS/Linux: /usr/bin/tesseract (usually auto-detected)
TESSERACT_PATH=

# Africa's Talking (USSD/SMS)
AT_USERNAME=your-africastalking-username
AT_API_KEY=your-africastalking-api-key
# Optional sender ID if your account is approved for one
AT_SENDER_ID=
# Optional override for SMS endpoint
AT_SMS_URL=https://api.africastalking.com/version1/messaging
